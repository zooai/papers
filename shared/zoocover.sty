% zoocover.sty — Black cover page for all Lux research papers
% Usage: \usepackage{zoocover} then \zoocoverpage before \begin{document} content
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{zoocover}[2024/01/15 Zoo Research Cover Page]

\RequirePackage{tikz}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\@ifpackageloaded{geometry}{}{\RequirePackage{geometry}}

% Lux brand colors
\definecolor{luxblack}{RGB}{0,0,0}
\definecolor{luxwhite}{RGB}{255,255,255}
\definecolor{luxgold}{RGB}{207,181,59}
\definecolor{luxgray}{RGB}{128,128,128}

\newcommand{\zoocoverpage}{%
  \newgeometry{margin=0pt}
  \thispagestyle{empty}
  \begin{tikzpicture}[remember picture,overlay]
    % Full black background
    \fill[luxblack] (current page.south west) rectangle (current page.north east);

    % Diamond logo (centered, upper third)
    \node[luxwhite] at ([yshift=3cm]current page.center) {%
      \begin{tikzpicture}[scale=1.8]
        \draw[luxwhite, line width=1.5pt]
          (0,1.2) -- (1,0) -- (0,-1.2) -- (-1,0) -- cycle;
        \draw[luxwhite, line width=0.8pt]
          (0,0.8) -- (0.65,0) -- (0,-0.8) -- (-0.65,0) -- cycle;
        \draw[luxwhite, line width=0.4pt]
          (0,0.4) -- (0.3,0) -- (0,-0.4) -- (-0.3,0) -- cycle;
      \end{tikzpicture}%
    };

    % Title
    \node[luxwhite, font=\fontsize{28}{34}\selectfont\bfseries\sffamily,
          text width=14cm, align=center]
      at ([yshift=-0.5cm]current page.center) {\@title};

    % Author
    \node[luxgray, font=\fontsize{11}{14}\selectfont\sffamily,
          text width=14cm, align=center]
      at ([yshift=-2.5cm]current page.center) {\@author};

    % Date
    \node[luxgold, font=\fontsize{10}{12}\selectfont\sffamily]
      at ([yshift=-3.8cm]current page.center) {\@date};

    % Bottom bar
    \fill[luxgold] ([yshift=0.8cm]current page.south west)
      rectangle ([yshift=0.85cm]current page.south east);

    % Footer text
    \node[luxwhite, font=\fontsize{8}{10}\selectfont\sffamily, anchor=south]
      at ([yshift=0.2cm]current page.south) {%
        Zoo Labs Foundation \quad $\cdot$ \quad Hanzo AI \quad $\cdot$ \quad Zoo Labs Foundation%
      };

    % Classification
    \node[luxgray, font=\fontsize{7}{9}\selectfont\sffamily, anchor=south east]
      at ([xshift=-1cm,yshift=1.2cm]current page.south east) {RESEARCH};
  \end{tikzpicture}
  \restoregeometry
  \newpage
}

\let\zoocover\zoocoverpage
\let\luxcoverpage\zoocoverpage
